        },
        "limit": 1
      },
      "id": "next",
      "name": "Get Next Pair",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [
        128,
        0
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Normalize Update').first().json;\nconst rows = $input.all().filter(i => i.json && i.json.pair_id !== undefined);\nif (rows.length === 0) {\n  return [{ json: { has_pending: false, chat_id: ctx.chat_id,\n    message_text: '✅ Review queue is empty — every uncertain pair has been resolved. The mapping tables are up to date.' }}];\n}\nconst r = rows[0].json;\nconst lines = [\n  `🔍 *Entity review* — ${r.entity}`,\n  '',\n  `A: ${r.raw_a}`,\n  `B: ${r.raw_b}`,\n  '',\n  `model score: ${Number(r.score).toFixed(2)}   |   revenue at stake: EGP ${Number(r.impact_egp).toLocaleString()}`,\n];\nif (r.suggestion) lines.push(`💡 price evidence: *${r.suggestion}*`);\nlines.push('', 'Same real-world entity?');\nreturn [{ json: { has_pending: true, chat_id: ctx.chat_id, pair_id: r.pair_id,\n  message_text: lines.join('\\n') }}];"
      },
      "id": "compose",
      "name": "Compose Review Card",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        352,
