          "value": {
            "decision": "={{ $('Normalize Update').first().json.decision }}",
            "status": "done"
          },
          "matchingColumns": [],
          "schema": []
        },
        "options": {}
      },
      "id": "save",
      "name": "Save Decision",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [
        -128,
        -160
      ]
    },
    {
      "parameters": {
        "operation": "get",
        "dataTableId": {
          "__rl": true,
          "mode": "id",
          "value": "kyjcN3233zocREtV",
          "cachedResultName": "hitl_review_queue"
        },
